# --- AI translation backend ---------------------------------------------
# Provide an Anthropic API key to enable real Claude-powered translation.
# Without it, the app runs on a clearly-labelled mock provider so the full
# UI still works end to end.
ANTHROPIC_API_KEY=

# Model used for translation (optional; sensible default is applied).
# See the Claude API reference for current model ids.
TRANSLATION_MODEL=claude-opus-4-8

# Force a provider regardless of the key: "claude" | "mock" | "auto" (default)
TRANSLATION_PROVIDER=auto
